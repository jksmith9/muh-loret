# Environment variable overrides for Docker Compose.
# Copy this file to .env and customise as needed.
# docker compose will pick up .env automatically.

# URL of the Ollama instance on the host machine.
# macOS / Windows Docker Desktop: use host.docker.internal
# Linux Docker Engine:            use 172.17.0.1 (default bridge gateway)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama model tag
OLLAMA_MODEL=gemma4:e4b

# Comma-separated allowed CORS origins (use * for open access)
CORS_ORIGINS=*

# Set to "true" to include raw LLM output in API responses (dev only)
DEBUG_RESPONSES=false
